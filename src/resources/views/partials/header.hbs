<header id="main-header" class="flex a-center p-fixed t-0 r-0">
    {{#each results}}
    <div class="account flex a-center">
        <img src="{{Image}}" alt="">
        <a href="/login" id="loginButton">
            <h4 class="name">{{UserName}}</h4>
        </a>
    </div>
    {{/each}}



    <!-- thanh tìm kiếm nhạc -->
    <form action="/search" class="search">
        <div class="input-group">
            <button type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <input type="text" name="query" id="search" placeholder="Search for music">
        </div>
    </form>


    <!-- account -->

</header>