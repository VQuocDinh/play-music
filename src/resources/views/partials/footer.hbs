<div class="player-control flex a-center j-between p-fixed b-0 l-0">
  <div class="list-music flex">
    <a href=""><img src="/img/Rectangle 33.png" alt="" /></a>
    <div class="detail">
      <h3>Ghostmusic</h3>
      <a href="">Derva</a>
    </div>
  </div>
  <div class="control-bar flex a-center j-center">
    <div class="actions">
      <button class="backward"><i
          class="fa-solid fa-backward-step"
        ></i></button>
      <button class="pause"><i class="fa-solid fa-circle-pause"></i></button>
      <button class="forward"><i class="fa-solid fa-forward-step"></i></button>
    </div>
    <div class="duration-bar flex a-center j-center">
      <span class="tiem left">
        00:00
      </span>
      <input
        class="time-bar"
        type="range"
        oninput="setVolume()"
        id="volume1"
        min="0"
        max="1"
        step="0.01"
        value="0"
        onclick="play() "
      />
      <span class="time right">
        3:00
      </span>
    </div>

  </div>

  <div class="volume flex a-center">
    <i class="fa-solid fa-volume-high"></i>
    <input
      class="volume-bar"
      type="range"
      oninput="setVolume()"
      id="volume1"
      min="0"
      max="1"
      step="0.01"
      value="0"
      onclick="play() "
    />
  </div>
</div>