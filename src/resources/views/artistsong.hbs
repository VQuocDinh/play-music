<div class="main-page">
    <div class="album-detail-container flex j-between">
        <div class="album-poster flex  a-center">
            <a class="poster" href=""><img src="/img/Rectangle 5.png" alt=""></a>
            <h3 class="name-album">Ghostmusic</h3>
            <a href="" class="author">Derva</a>
            <button class="play">Tiếp tục phát</button>
            <div class="btns">
                <button class="delete "><i class="fa-solid fa-xmark"></i></button>
                <button class="more "><i class="fa-solid fa-ellipsis"></i></button>
            </div>
        </div>
        <div class="album-song">
            <div class="header flex a-center">
                <button class="arrange"><i class="fa-solid fa-arrow-up-z-a"></i></button>
                <h3>Bài hát</h3>
                <div class="line"></div>
            </div>
            <div class="media-list">
                {{#each artistsong}}
                <div class="media-item flex a-center j-between">
                    <div class="media-left flex a-center ">
                        <a href=""><img src="../image/Rectangle 33.png" alt=""></a>
                        <div class="detail">
                            <h3>Ghostmusic</h3>
                            <a href="">Derva</a>
                        </div>
                    </div>
                    <div class="media-right">
                        <span class="time">2:10</span>
                        <button class="heart "><i class="fa-solid fa-heart like"></i></button>
                        <button class="plus"><i class="fa-solid fa-plus "></i></button>
                    </div>
                </div>
                {{/each}}

            </div>
        </div>
    </div>
</div>